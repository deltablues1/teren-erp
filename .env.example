# Telegram bot token (kreiraj kod @BotFather)
TELEGRAM_BOT_TOKEN=

# Anthropic Claude API ključ (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI API ključ za Whisper transkripciju (https://platform.openai.com)
OPENAI_API_KEY=

# Putanja do Google Service Account JSON ključa
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-sa.json

# ID Google Drive foldera u kojem se kreiraju projektni Sheets-i
# (otvori folder u Drive-u, ID je dio URL-a: https://drive.google.com/drive/folders/<ID>)
GOOGLE_SHEETS_FOLDER_ID=

# Tvoj Telegram ID (admin) - samo on može pokretati /noviprojekt, /dnevnik itd.
# Da saznaš svoj ID, pokreni bota i pošalji mu /id
ADMIN_TELEGRAM_ID=

# OpenWeatherMap API ključ (opcionalno - za auto-povlačenje vremenskih prilika)
# https://openweathermap.org/api - besplatan tier je dovoljan
OPENWEATHER_API_KEY=

# Claude model (default je sonnet 4.6, za jeftiniji rad koristi haiku-4-5)
CLAUDE_MODEL=claude-sonnet-4-6

# Vremenska zona za datume
TIMEZONE=Europe/Zagreb

# Sloj podataka: "sheets" (Google Sheets) ili "postgres" (PostgreSQL).
DATA_BACKEND=sheets

# PostgreSQL veza (potrebno samo ako je DATA_BACKEND=postgres).
# Format: postgresql+psycopg://korisnik:lozinka@host:port/baza
DATABASE_URL=postgresql+psycopg://postgres:LOZINKA@localhost:5432/teren_bot

# Web admin panel — lozinka za prijavu (prazno = bez prijave, samo za lokalni rad).
WEB_PASSWORD=
# Tajni ključ za potpis sesije (promijeni u nasumičan niz).
WEB_SECRET=teren-web-secret-promijeni-me

# Podaci firme za zaglavlje PONUDA (sve opcionalno — prikazuje se što je popunjeno)
FIRMA_NAZIV=
FIRMA_ADRESA=
FIRMA_OIB=
FIRMA_IBAN=
FIRMA_TELEFON=
FIRMA_EMAIL=
